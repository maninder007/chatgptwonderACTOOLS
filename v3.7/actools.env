# =============================================================================
# Actools v3.12 environment configuration
# Save this file as ~/actools.env
# =============================================================================

# Base domain for production site
BASE_DOMAIN="feesix.com"

# Email used by Caddy to request Let's Encrypt certificates for prod
DRUPAL_ADMIN_EMAIL="you@example.com"

# MariaDB root password (strong random string recommended)
DB_ROOT_PASS="#ReplaceWithStrongPassword"

# Optional overrides (default values used if empty)
SECURITY_PROFILE="baseline"      # baseline | standard | hardened
PHP_VERSION="8.3"                # PHP version for Drupal container
MARIADB_VERSION="11.4"           # MariaDB version
DRUPAL_VERSION="11.0"            # Drupal project version
