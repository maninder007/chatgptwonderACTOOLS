cat <<'EOF' > ~/actools.env
# =============================================================================
# Actools Configuration
# =============================================================================

# Domain (used for final output)
BASE_DOMAIN=feesix.com.com

# Drupal admin email
DRUPAL_ADMIN_EMAIL=mpal_singh@yahoo.com

# MariaDB root password (CHANGE THIS!)
DB_ROOT_PASS=StrongRootPassword123!

# =============================================================================
# Versions
# =============================================================================

# PHP version used by Drupal container
PHP_VERSION=8.3

# MariaDB version
MARIADB_VERSION=11.4

# Drupal version (recommended: 11.x)
DRUPAL_VERSION=11

# =============================================================================
# Security Profile
# =============================================================================

# Options: baseline | standard | hardened
SECURITY_PROFILE=baseline

EOF
